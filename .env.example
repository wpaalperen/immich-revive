# immich url (e.g. http://192.168.1.100:2283)
IMMICH_URL=http://localhost:2283

# admin api key (account settings -> api keys)
IMMICH_API_KEY=your_api_key_here

# check interval in seconds
CHECK_INTERVAL=120

# queues to monitor (comma-separated)
MONITORED_JOBS=faceDetection,smartSearch,metadataExtraction
